<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Order Processing</title>

<style>

/* ===========================
GLOBAL STYLE
=========================== */

body{
margin:0;
padding:0;
font-family: Arial, Helvetica, sans-serif;
background: linear-gradient(135deg,#667eea,#764ba2);
color:#333;
}

.email-wrapper{
max-width:700px;
margin:40px auto;
background:white;
border-radius:20px;
overflow:hidden;
box-shadow:0 20px 60px rgba(0,0,0,.15);
}

/* HEADER */

.email-header{
background: linear-gradient(135deg,#f093fb,#f5576c);
padding:40px;
text-align:center;
color:white;
}

.logo{
max-width:180px;
border-radius:12px;
box-shadow:0 8px 25px rgba(0,0,0,.2);
}

.brand-name{
font-size:28px;
font-weight:bold;
margin-top:15px;
}

/* BODY */

.email-body{
padding:40px;
background:white;
}

.processing-badge{
background: linear-gradient(135deg,#ed8936,#dd6b20);
color:white;
padding:12px 24px;
border-radius:25px;
font-weight:bold;
display:inline-block;
}

/* PRODUCT */

.product-item{
display:flex;
align-items:center;
padding:20px;
background:#f8f9fa;
border-radius:12px;
margin-bottom:15px;
border:1px solid #e9ecef;
transition: transform 0.3s ease;
}

.product-item:hover{
transform: translateY(-3px);
}

.product-img{
width:80px;
height:80px;
object-fit:cover;
border-radius:8px;
margin-right:20px;
}

.product-details{
flex:1;
}

.product-title{
font-weight:bold;
color:#2d3748;
}

.product-price{
color:#718096;
font-size:14px;
}

/* TIMELINE PROGRESS BAR ⭐ ENTERPRISE UX */

.progress-container{
margin:40px 0;
}

.progress-bar-bg{
height:14px;
border-radius:20px;
background:#e2e8f0;
overflow:hidden;
}

.progress-bar-fill{
height:100%;
border-radius:20px;
background: linear-gradient(135deg,#48bb78,#38a169);
width:<%= progress || 0 %>%;
transition: width 0.5s ease;
}

/* CTA BUTTON */

.cta-button{
display:inline-block;
background: linear-gradient(135deg,#667eea,#764ba2);
color:white;
padding:15px 35px;
border-radius:30px;
text-decoration:none;
font-weight:bold;
transition: opacity 0.3s ease;
}

.cta-button:hover{
opacity:0.9;
}

/* FOOTER */

.email-footer{
background: linear-gradient(135deg,#2d3748,#1a202c);
padding:40px;
text-align:center;
color:#a0aec0;
}

/* RESPONSIVE */

@media(max-width:600px){

.email-wrapper{
margin:20px;
}

.product-item{
flex-direction:column;
text-align:center;
}

.product-img{
margin:0 0 15px 0;
}

}

</style>
</head>

<body>

<div class="email-wrapper">

<!-- HEADER -->

<div class="email-header">

<img src="https://res.cloudinary.com/dkdx7xytz/image/upload/v1772469610/blisslogo1_rwlktl.png"
class="logo"/>

<div class="brand-name">Kilifonia Beauty</div>
<p>Elevate Your Natural Beauty</p>

</div>

<!-- BODY -->

<div class="email-body">

<div style="text-align:center;margin-bottom:30px;">
<div class="processing-badge">
⏳ ORDER PROCESSING
</div>
</div>

<h1 style="text-align:center;background:linear-gradient(135deg,#f093fb,#f5576c);-webkit-background-clip:text;color:transparent;">
Hello <%= name %>
</h1>

<p style="text-align:center;font-size:18px;">
Your order is currently being processed.
We are preparing your premium skincare products.
</p>

<!-- ⭐ PROGRESS BAR -->
<div class="progress-container">

<p style="text-align:center;font-weight:bold;margin-bottom:10px;">
Order Progress
</p>

<div class="progress-bar-bg">
<div class="progress-bar-fill"></div>
</div>

</div>

<hr style="margin:30px 0;border:0;height:2px;background:linear-gradient(90deg,transparent,#667eea,transparent)"/>

<h2>Your Order Details</h2>

<div class="product-list">

<% products.forEach(product => { %>

<div class="product-item">

<img src="<%= product.img || 'https://via.placeholder.com/80' %>"
class="product-img"/>

<div class="product-details">
<p class="product-title"><%= product.title %></p>
<p class="product-price">
Price: $<%= product.price %>
</p>

<% if(product.quantity){ %>
<p class="product-price">
Quantity: <%= product.quantity %>
</p>
<% } %>

</div>

</div>

<% }) %>

</div>

<div style="text-align:center;margin-top:30px;">
<a href="https://kilifoniabeauty.co.ke/track-order"
class="cta-button">
Track Order Status
</a>
</div>

</div>

<!-- FOOTER -->

<div class="email-footer">

<p style="color:#f5576c;font-weight:bold;font-size:18px;">
Kilifonia Beauty
</p>

<p>Elevating Beauty Through Science and Nature</p>

<p>
&copy; <%= new Date().getFullYear() %> Kilifonia Beauty. All rights reserved.
</p>

</div>

</div>

</body>
</html>