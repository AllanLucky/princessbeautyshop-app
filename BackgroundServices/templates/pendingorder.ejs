<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Order Processing</title>

<style>
body{
margin:0;
padding:0;
font-family: Arial, Helvetica, sans-serif;
background:#f4f4f4; 
}

.email-wrapper{
max-width:700px;
margin:20px auto;
background:#ffffff;
border-radius:12px;
overflow:hidden;
}

/* HEADER */
.email-header{
background:#f5576c;
padding:30px;
text-align:center;
color:white;
}

.logo{
max-width:150px;
border-radius:10px;
}

.brand-name{
font-size:24px;
font-weight:bold;
margin-top:10px;
}

/* BODY */
.email-body{
padding:30px;
}

.processing-badge{
background:#dd6b20;
color:white;
padding:10px 20px;
border-radius:20px;
font-weight:bold;
display:inline-block;
}

/* PROGRESS */
.progress-bar-bg{
height:12px;
border-radius:20px;
background:#e2e8f0;
overflow:hidden;
}

.progress-bar-fill{
height:100%;
background:#38a169;
border-radius:20px;
}

/* FOOTER */
.email-footer{
background:#1a202c;
padding:30px;
text-align:center;
color:#a0aec0;
}

@media(max-width:600px){
.email-body{
padding:20px;
}
}
</style>
</head>

<body>

<!-- PREVIEW TEXT -->
<div style="display:none;max-height:0;overflow:hidden;">
Your order is being processed. Track it now.
</div>

<div class="email-wrapper">

<!-- HEADER -->
<div class="email-header">
<img src="https://res.cloudinary.com/dkdx7xytz/image/upload/v1772469610/blisslogo1_rwlktl.png" class="logo"/>
<div class="brand-name">Kilifonia Beauty</div>
<p>Elevate Your Natural Beauty</p>
</div>

<!-- BODY -->
<div class="email-body">

<div style="text-align:center;margin-bottom:25px;">
<span class="processing-badge">⏳ ORDER PROCESSING</span>
</div>

<h2 style="text-align:center;">
Hello <%= name %>
</h2>

<p style="text-align:center;font-size:16px;">
Your order is currently being processed.  
We are preparing your premium skincare products.
</p>

<!-- PROGRESS BAR -->
<div style="margin:30px 0;">
<p style="text-align:center;font-weight:bold;">Order Progress</p>

<div class="progress-bar-bg">
<div class="progress-bar-fill" style="width:<%= progress || 0 %>%;"></div>
</div>
</div>

<hr style="margin:30px 0;border:0;height:1px;background:#eee"/>

<h3>Your Order Details</h3>

<!-- PRODUCTS -->
<% products.forEach(product => { %>

<table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:15px;border:1px solid #eee;border-radius:8px;">
<tr>

<td width="90" valign="top" style="padding:10px;">
<img src="<%= product.img || 'https://via.placeholder.com/80' %>"
style="width:80px;height:80px;border-radius:6px;object-fit:cover;" />
</td>

<td valign="top" style="padding:10px;">
<p style="font-weight:bold;margin:0;">
<%= product.title %>
</p>

<p style="margin:5px 0;color:#555;">
Price: $<%= product.price %>
</p>

<% if(product.quantity){ %>
<p style="margin:0;color:#777;">
Quantity: <%= product.quantity %>
</p>
<% } %>

</td>

</tr>
</table>

<% }) %>

<!-- BUTTON -->
<div style="text-align:center;margin-top:25px;">
<table align="center" cellpadding="0" cellspacing="0">
<tr>
<td bgcolor="#667eea" style="border-radius:25px;">
<a href="https://kilifoniabeauty.co.ke/track-order"
style="display:inline-block;padding:12px 25px;color:#ffffff;text-decoration:none;font-weight:bold;">
Track Order Status
</a>
</td>
</tr>
</table>
</div>

</div>

<!-- FOOTER -->
<div class="email-footer">

<p style="color:#f5576c;font-weight:bold;font-size:16px;">
Kilifonia Beauty
</p>

<p>Elevating Beauty Through Science and Nature</p>

<p>
&copy; <%= new Date().getFullYear() %> Kilifonia Beauty. All rights reserved.
</p>

</div>

</div>

</body>
</html>