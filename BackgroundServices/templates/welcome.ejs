<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Welcome to Kilifonia Beauty</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600;700&display=swap');

body {
  margin: 0;
  padding: 0;
  font-family: 'Inter', sans-serif;
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.email-wrapper {
  max-width: 700px;
  margin: 40px auto;
  background: #fff;
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 0 20px 60px rgba(0,0,0,.15);
}

.header {
  background: linear-gradient(135deg, #f093fb, #f5576c);
  text-align: center;
  padding: 50px 30px;
  color: white;
}

.logo {
  max-width: 180px;
  border-radius: 12px;
  box-shadow: 0 8px 25px rgba(0,0,0,.2);
}

.brand-name {
  font-family: 'Playfair Display', serif;
  font-size: 28px;
  font-weight: 700;
  margin-top: 15px;
}

.badge {
  display: inline-block;
  margin-top: 20px;
  background: linear-gradient(135deg, #48bb78, #38a169);
  padding: 15px 30px;
  border-radius: 30px;
  font-weight: 700;
  animation: pulse 2s infinite;
}

.body {
  padding: 50px 40px;
}

h1 {
  font-family: 'Playfair Display', serif;
  text-align: center;
  font-size: 36px;
  background: linear-gradient(135deg, #f093fb, #f5576c);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 25px;
}

p {
  color: #4a5568;
  line-height: 1.6;
  font-size: 16px;
}

.section {
  background: linear-gradient(135deg, #f8f9fa, #fff);
  padding: 30px;
  border-radius: 15px;
  margin: 35px 0;
  border: 1px solid #eee;
  text-align: center;
}

.section h3 {
  font-family: 'Playfair Display', serif;
  margin-bottom: 15px;
  font-size: 22px;
}

.product-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 25px;
  margin-top: 20px;
}

.product-item {
  background: linear-gradient(135deg,#f8f9fa,#fff);
  padding: 20px;
  border-radius: 15px;
  border: 1px solid #eee;
  width: 200px;
  text-align: center;
}

.product-item img {
  width: 120px;
  height: 120px;
  object-fit: cover;
  border-radius: 12px;
  margin-bottom: 10px;
}

.cta {
  display: inline-block;
  padding: 18px 45px;
  border-radius: 30px;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  font-weight: 700;
  text-decoration: none;
  margin: 15px 10px;
  box-shadow: 0 8px 25px rgba(102,126,234,.4);
  transition: all 0.3s ease;
}

.cta:hover {
  transform: translateY(-3px);
}

.footer {
  background: linear-gradient(135deg, #2d3748, #1a202c);
  color: #a0aec0;
  text-align: center;
  padding: 50px 30px;
}

.footer p {
  margin: 8px 0;
}

.social a {
  color: #a0aec0;
  margin: 0 12px;
  text-decoration: none;
  font-weight: 500;
}

.social a:hover {
  color: #f093fb;
}

@keyframes pulse {
  50% { transform: scale(1.05); }
}

@media (max-width: 600px) {
  .body { padding: 30px 20px; }
  h1 { font-size: 28px; }
  .cta { padding: 15px 30px; font-size: 14px; }
  .section { padding: 20px; }
}
</style>
</head>

<body>
<div class="email-wrapper">

  <div class="header">
    <img class="logo" src="https://res.cloudinary.com/dkdx7xytz/image/upload/v1772469610/blisslogo1_rwlktl.png" alt="Kilifonia Beauty Logo" />
    <div class="brand-name">Kilifonia Beauty</div>
    <div class="badge">🎉 WELCOME TO THE KILIFONIA FAMILY</div>
  </div>

  <div class="body">
    <h1>Welcome to Luxury Skincare, <%= name %>!</h1>
    <p style="text-align:center;">
      We are delighted to welcome you to Kilifonia Beauty, where science meets luxury skincare.
      Start your transformation journey with premium formulations designed for your skin.
    </p>

    <div class="section">
      <h3>✨ Personalized Skincare Experience</h3>
      <p>
        Receive expert skincare recommendations tailored to your skin type and concerns.
        Enjoy science-backed formulations, luxurious textures, and visible results.
      </p>

      <% if(products && products.length){ %>
        <div class="product-list">
          <% products.forEach(product => { %>
            <div class="product-item">
              <img src="<%= product.img || 'https://via.placeholder.com/120' %>" alt="<%= product.name %>">
              <h4><%= product.name %></h4>
              <p><%= product.description %></p>
              <% if(product.price){ %>
                <p style="font-weight:bold;color:#f5576c;">$<%= product.price %></p>
              <% } %>
              <% if(product.link){ %>
                <a href="<%= product.link %>" class="cta" style="padding:10px 20px;font-size:14px;">Shop Now</a>
              <% } %>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div style="text-align:center">
      <a href="https://kilifoniabeauty.co.ke/shop" class="cta">Explore Collection</a>
      <a href="https://kilifoniabeauty.co.ke/skincare-timetable" class="cta" style="background:linear-gradient(135deg,#f093fb,#f5576c)">
        Create Skincare Timetable
      </a>
    </div>
  </div>

  <div class="footer">
    <p><strong style="color:#f5576c">Kilifonia Beauty</strong><br>Elevating Beauty Through Science and Nature</p>
    <div class="social">
      <a href="https://kilifoniabeauty.co.ke">Website</a> |
      <a href="https://instagram.com/kilifoniabeauty">Instagram</a> |
      <a href="https://facebook.com/kilifoniabeauty">Facebook</a>
    </div>
    <p style="font-size:12px;margin-top:30px;">© <%= new Date().getFullYear() %> Kilifonia Beauty. All rights reserved.</p>
  </div>

</div>
</body>
</html>