<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Order Confirmed</title>
<style>
/* ===========================
GLOBAL STYLES
=========================== */
body {
    font-family: Arial, Helvetica, sans-serif;
    background: linear-gradient(135deg,#667eea,#764ba2);
    margin: 0;
    padding: 0;
    color: #333;
}

.wrapper {
    max-width: 700px;
    margin: 40px auto;
    background: white;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0,0,0,0.15);
}

/* HEADER */
.header {
    background: linear-gradient(135deg,#38a169,#48bb78);
    color: white;
    text-align: center;
    padding: 40px;
}

.badge {
    display: inline-block;
    background: white;
    color: #38a169;
    padding: 12px 25px;
    border-radius: 25px;
    font-weight: bold;
    margin-bottom: 15px;
}

.header h1 {
    font-size: 28px;
    margin: 10px 0;
}

.header p {
    font-size: 16px;
    margin: 0;
}

/* BODY */
.body {
    padding: 40px;
}

/* PROGRESS BAR */
.progress-box {
    margin-top: 30px;
    padding: 20px;
    background: #f7fafc;
    border-radius: 12px;
    text-align: center;
}

.progress-bar {
    width: 100%;
    background: #e2e8f0;
    border-radius: 20px;
    height: 14px;
    overflow: hidden;
    margin-top: 10px;
}

.progress-fill {
    height: 100%;
    background: linear-gradient(135deg,#48bb78,#38a169);
    width: <%= progress || 0 %>%;
    transition: width 0.5s ease;
    border-radius: 20px;
}

/* PRODUCT ITEMS */
.product {
    background: #f8f9fa;
    padding: 20px;
    border-radius: 12px;
    margin-top: 20px;
}

.product img {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: 8px;
    margin-right: 10px;
    vertical-align: middle;
}

.product p {
    margin: 10px 0;
}

.product hr {
    border: 0;
    border-top: 1px solid #e2e8f0;
}

/* AMOUNT SUMMARY */
.amount-summary {
    background: #f1f5f9;
    padding: 15px 20px;
    border-radius: 12px;
    margin-top: 20px;
}

.amount-summary p {
    margin: 5px 0;
    font-size: 14px;
}

/* CTA / INFO */
.body p {
    font-size: 16px;
    line-height: 1.5;
}

/* FOOTER */
.footer {
    background: #1a202c;
    color: #a0aec0;
    text-align: center;
    padding: 30px;
    font-size: 14px;
}

/* RESPONSIVE */
@media(max-width: 600px){
    .body {
        padding: 20px;
    }
    .header {
        padding: 20px;
    }
    .product {
        padding: 15px;
    }
    .progress-box {
        padding: 15px;
    }
}
</style>
</head>

<body>

<div class="wrapper">

    <!-- HEADER -->
    <div class="header">
        <div class="badge">✅ ORDER CONFIRMED</div>
        <h1>Hello <%= name || "Customer" %></h1>
        <p>Your order has been successfully confirmed.</p>
    </div>

    <!-- BODY -->
    <div class="body">

        <p>
            Great news! Your order <strong>#<%= orderNumber || "N/A" %></strong> is now confirmed
            and being prepared for shipment.
        </p>

        <!-- ORDER PROGRESS -->
        <div class="progress-box">
            <h3>Order Progress</h3>
            <p>Status: <strong><%= statusText || "Confirmed" %></strong></p>

            <div class="progress-bar">
                <div class="progress-fill"></div>
            </div>

            <p style="margin-top:10px;">
                <%= progress || 0 %>% Completed
            </p>

            <p>
                Estimated Delivery:<br>
                <strong><%= estimatedDeliveryDate || "To be announced" %></strong>
            </p>
        </div>

        <!-- PRODUCTS -->
        <div class="product">
            <h3>Order Summary</h3>

            <% if (products && products.length) { %>
                <% products.forEach(product => { %>
                    <p>
                        <% if(product.img){ %>
                            <img src="<%= product.img %>" alt="<%= product.title || 'Product' %>"/>
                        <% } %>
                        <b><%= product.title || "Product" %></b><br>
                        Quantity: <%= product.quantity || 0 %><br>
                        Price: KES <%= product.price || 0 %>
                    </p>
                    <hr/>
                <% }) %>
            <% } else { %>
                <p>No product information available.</p>
            <% } %>

            <div class="amount-summary">
                <p><strong>Total Amount:</strong> KES <%= total || 0 %></p>
                <% if(typeof amountPaid !== "undefined"){ %>
                    <p><strong>Amount Paid:</strong> KES <%= amountPaid %></p>
                    <p><strong>Balance:</strong> KES <%= (total - amountPaid) %></p>
                <% } %>
            </div>
        </div>

        <p style="margin-top:30px;">
            We will notify you once your order is shipped. Thank you for shopping with us ❤️
        </p>

    </div>

    <!-- FOOTER -->
    <div class="footer">
        Kilifonia Beauty © <%= new Date().getFullYear() %>
    </div>

</div>

</body>
</html>