<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Order Confirmed</title>

<style>

body{
font-family:Arial,Helvetica,sans-serif;
background:linear-gradient(135deg,#667eea,#764ba2);
margin:0;
padding:0;
}

.wrapper{
max-width:700px;
margin:40px auto;
background:white;
border-radius:20px;
overflow:hidden;
box-shadow:0 20px 60px rgba(0,0,0,.15);
}

.header{
background:linear-gradient(135deg,#38a169,#48bb78);
color:white;
text-align:center;
padding:40px;
}

.badge{
display:inline-block;
background:white;
color:#38a169;
padding:12px 25px;
border-radius:25px;
font-weight:bold;
}

.body{
padding:40px;
}

.product{
background:#f8f9fa;
padding:20px;
border-radius:12px;
margin-top:20px;
}

.progress-box{
margin-top:30px;
padding:20px;
background:#f7fafc;
border-radius:12px;
text-align:center;
}

.progress-bar{
width:100%;
background:#e2e8f0;
border-radius:20px;
height:12px;
overflow:hidden;
margin-top:10px;
}

.progress-fill{
height:12px;
background:#38a169;
}

.footer{
background:#1a202c;
color:#a0aec0;
text-align:center;
padding:30px;
}

</style>

</head>

<body>

<div class="wrapper">

<div class="header">

<div class="badge">✅ ORDER CONFIRMED</div>

<h1>Hello <%= name %></h1>

<p>Your order has been successfully confirmed.</p>

</div>

<div class="body">

<p>
Great news! Your order <strong>#<%= orderNumber %></strong> is now confirmed
and being prepared for shipment.
</p>


<!-- ORDER PROGRESS SECTION -->

<div class="progress-box">

<h3>Order Progress</h3>

<p>Status: <strong><%= statusText %></strong></p>

<div class="progress-bar">
<div class="progress-fill" style="width:<%= progress %>%"></div>
</div>

<p style="margin-top:10px">
<%= progress %>% Completed
</p>

<p>
Estimated Delivery:<br>
<strong><%= estimatedDeliveryDate %></strong>
</p>

</div>


<div class="product">

<h3>Order Summary</h3>

<% products.forEach(product => { %>

<p>
<b><%= product.title %></b><br>
Quantity: <%= product.quantity %><br>
Price: KES <%= product.price %>
</p>

<hr/>

<% }) %>

<p>
<strong>Total Amount:</strong> KES <%= total %>
</p>

</div>


<p style="margin-top:30px">
We will notify you once your order is shipped.
Thank you for shopping with us ❤️
</p>

</div>


<div class="footer">

Kilifonia Beauty © <%= new Date().getFullYear() %>

</div>

</div>

</body>
</html>