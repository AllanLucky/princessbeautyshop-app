<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Order Shipped</title>

<style>
body {
  font-family: Arial, Helvetica, sans-serif;
  background: linear-gradient(135deg,#667eea,#764ba2);
  margin: 0;
  padding: 0;
  color: #333;
}

.email-wrapper {
  max-width: 700px;
  margin: 40px auto;
  background: #ffffff;
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 0 20px 60px rgba(0,0,0,0.15);
}

.email-header {
  background: linear-gradient(135deg,#3182ce,#2b6cb0);
  padding: 40px 20px;
  text-align: center;
  color: white;
}

.logo {
  max-width: 180px;
  border-radius: 12px;
  box-shadow: 0 8px 25px rgba(0,0,0,.2);
}

.brand-name {
  font-size: 28px;
  font-weight: bold;
  margin-top: 15px;
}

.shipped-badge {
  display: inline-block;
  background: linear-gradient(135deg,#63b3ed,#3182ce);
  color: white;
  padding: 12px 24px;
  border-radius: 25px;
  font-weight: bold;
  margin-top: 15px;
}

.email-body {
  padding: 40px 20px;
}

h1 {
  text-align: center;
  font-size: 24px;
  margin-bottom: 10px;
}

p {
  text-align: center;
  font-size: 18px;
  line-height: 1.6;
}

.progress-container {
  background: #e2e8f0;
  border-radius: 25px;
  height: 20px;
  margin: 30px 0;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  width: <%= progress %>%;
  background: linear-gradient(135deg,#3182ce,#2b6cb0);
  border-radius: 25px;
  text-align: right;
  line-height: 20px;
  color: white;
  font-weight: bold;
  padding-right: 10px;
  transition: width 0.5s ease;
}

.product-item {
  display: flex;
  align-items: center;
  padding: 20px;
  background: #f8f9fa;
  border-radius: 12px;
  margin-bottom: 15px;
}

.product-img {
  width: 80px;
  height: 80px;
  object-fit: cover;
  border-radius: 8px;
  margin-right: 20px;
}

.product-details {
  flex: 1;
}

.product-title {
  font-weight: bold;
  color: #2d3748;
  margin-bottom: 5px;
}

.product-price {
  color: #718096;
  font-size: 14px;
  margin: 2px 0;
}

.cta-button {
  display: inline-block;
  background: linear-gradient(135deg,#667eea,#764ba2);
  color: white;
  padding: 15px 35px;
  border-radius: 30px;
  text-decoration: none;
  font-weight: bold;
  margin-top: 20px;
  transition: opacity 0.3s ease;
}

.cta-button:hover {
  opacity: 0.9;
}

.email-footer {
  background: linear-gradient(135deg,#2d3748,#1a202c);
  padding: 40px 20px;
  text-align: center;
  color: #a0aec0;
  font-size: 14px;
}

@media(max-width:600px){
  .email-body {
    padding: 20px;
  }
  .product-item {
    flex-direction: column;
    text-align: center;
  }
  .product-img {
    margin: 0 0 15px 0;
  }
  .cta-button {
    width: 100%;
    box-sizing: border-box;
  }
}
</style>
</head>

<body>

<div class="email-wrapper">

  <!-- HEADER -->
  <div class="email-header">
    <img src="https://res.cloudinary.com/dkdx7xytz/image/upload/v1772469610/blisslogo1_rwlktl.png" class="logo" alt="Kilifonia Beauty Logo"/>
    <div class="brand-name">Kilifonia Beauty</div>
    <div class="shipped-badge">📦 ORDER SHIPPED</div>
  </div>

  <!-- BODY -->
  <div class="email-body">
    <h1>Hello <%= name %></h1>
    <p>
      Great news! Your order <strong>#<%= orderNumber %></strong> has been shipped. 
      Your package is on the way 🚚
    </p>

    <!-- PROGRESS -->
    <div class="progress-container">
      <div class="progress-bar"><%= progress %>%</div>
    </div>

    <!-- PRODUCTS -->
    <h2 style="text-align:left;">Your Order Summary</h2>
    <% products.forEach(product => { %>
    <div class="product-item">
      <% if(product.img){ %>
      <img src="<%= product.img %>" class="product-img" alt="<%= product.title %>"/>
      <% } %>
      <div class="product-details">
        <p class="product-title"><%= product.title %></p>
        <p class="product-price">Quantity: <%= product.quantity %></p>
        <p class="product-price">Price: KES <%= product.price %></p>
      </div>
    </div>
    <% }) %>

    <div style="margin-top:25px;text-align:right;font-size:18px;">
      <strong>Total: KES <%= total %></strong>
    </div>

    <div style="text-align:center;">
      <a href="https://kilifoniabeauty.co.ke/track-order" class="cta-button">
        Track Your Order
      </a>
    </div>
  </div>

  <!-- FOOTER -->
  <div class="email-footer">
    <p style="color:#f5576c;font-weight:bold;font-size:16px;">Kilifonia Beauty</p>
    <p>Elevating Beauty Through Science and Nature</p>
    <p>&copy; <%= new Date().getFullYear() %> Kilifonia Beauty. All rights reserved.</p>
  </div>

</div>

</body>
</html>