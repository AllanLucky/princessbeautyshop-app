<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Order Processing</title>

<style>
body {
    font-family: Arial, Helvetica, sans-serif;
    background: linear-gradient(135deg, #667eea, #764ba2);
    margin: 0;
    padding: 0;
    color: #333;
}

.wrapper {
    max-width: 700px;
    margin: 40px auto;
    background: white;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0,0,0,0.15);
}

.header {
    background: linear-gradient(135deg, #ed8936, #dd6b20);
    color: white;
    text-align: center;
    padding: 40px;
}

.badge {
    display: inline-block;
    background: white;
    color: #dd6b20;
    padding: 12px 25px;
    border-radius: 25px;
    font-weight: bold;
}

.body {
    padding: 40px;
}

.product {
    background: #f8f9fa;
    padding: 20px;
    border-radius: 12px;
    margin-top: 20px;
}

/* Progress bar */
.progress-container {
    background: #e2e8f0;
    border-radius: 25px;
    height: 20px;
    margin: 30px 0;
    overflow: hidden;
}

.progress-bar {
    height: 100%;
    background: linear-gradient(135deg, #48bb78, #38a169);
    border-radius: 25px;
    text-align: right;
    line-height: 20px;
    color: white;
    font-weight: bold;
    padding-right: 10px;
    transition: width 0.5s ease;
    width: <%= progress || 0 %>%;
}

.footer {
    background: #1a202c;
    color: #a0aec0;
    text-align: center;
    padding: 30px;
}

@media(max-width:600px) {
    .body {
        padding: 20px;
    }
    .header {
        padding: 20px;
    }
}
</style>
</head>

<body>

<div class="wrapper">

<div class="header">
    <div class="badge">🔄 ORDER PROCESSING</div>
    <h1>Hello <%= name || "Customer" %></h1>
    <p>Your order is currently being prepared.</p>
</div>

<div class="body">
<p>
Your order <strong>#<%= orderNumber || "N/A" %></strong> is now in the processing stage.
Our team is preparing your products for shipment.
</p>

<div class="progress-container">
    <div class="progress-bar"><%= progress || 0 %>%</div>
</div>

<div class="product">
<h3>Order Summary</h3>

<% if (products && products.length) { %>
    <% products.forEach(product => { %>
        <p>
        <b><%= product.title || "Product" %></b><br>
        Quantity: <%= product.quantity || 0 %><br>
        Price: KES<%= product.price || 0 %>
        </p>
        <hr/>
    <% }) %>
<% } else { %>
    <p>No product information available.</p>
<% } %>

<p><strong>Total Amount:</strong> KES<%= total || 0 %></p>
</div>

<p style="margin-top:30px">
We will notify you once your order is shipped.
Thank you for trusting our service ❤️
</p>

</div>

<div class="footer">
Kilifonia Beauty © <%= new Date().getFullYear() %>
</div>

</div>

</body>
</html>