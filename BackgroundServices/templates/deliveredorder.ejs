<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Order Delivered</title>

<style>
/* =============================
GLOBAL STYLE
============================= */

body{
margin:0;
padding:0;
font-family: Arial, Helvetica, sans-serif;
background: linear-gradient(135deg,#667eea,#764ba2);
color:#333;
}

/* Wrapper */

.email-wrapper{
max-width:700px;
margin:40px auto;
background:white;
border-radius:20px;
overflow:hidden;
box-shadow:0 20px 60px rgba(0,0,0,0.15);
}

/* Header */

.email-header{
background: linear-gradient(135deg,#f093fb,#f5576c);
padding:40px;
text-align:center;
color:white;
}

.logo{
max-width:180px;
border-radius:12px;
box-shadow:0 8px 25px rgba(0,0,0,.2);
}

.brand-name{
font-size:28px;
font-weight:bold;
margin-top:15px;
}

/* Body */

.email-body{
padding:40px;
background:white;
}

.delivery-badge{
background: linear-gradient(135deg,#48bb78,#38a169);
color:white;
padding:12px 24px;
border-radius:25px;
font-weight:bold;
display:inline-block;
}

/* Footer */

.email-footer{
background: linear-gradient(135deg,#2d3748,#1a202c);
padding:40px;
text-align:center;
color:#a0aec0;
}

/* Button */

.cta-button{
display:inline-block;
background: linear-gradient(135deg,#667eea,#764ba2);
color:white;
padding:15px 35px;
border-radius:30px;
text-decoration:none;
font-weight:bold;
}

.cta-button:hover{
opacity:0.9;
}

</style>
</head>

<body>

<div class="email-wrapper">

<!-- HEADER -->
<div class="email-header">

<img src="https://res.cloudinary.com/dkdx7xytz/image/upload/v1772469610/blisslogo1_rwlktl.png"
class="logo"/>

<div class="brand-name">Kilifonia Beauty</div>
<p>Elevate Your Natural Beauty</p>

</div>

<!-- BODY -->
<div class="email-body">

<div style="text-align:center;margin-bottom:30px;">
<div class="delivery-badge">
🎉 ORDER DELIVERED SUCCESSFULLY
</div>
</div>

<h1 style="text-align:center;background:linear-gradient(135deg,#f093fb,#f5576c);-webkit-background-clip:text;color:transparent;">
Hello <%= name %>
</h1>

<p style="text-align:center;font-size:18px;">
Great news! Your Kilifonia Beauty order has been delivered.
We are happy to be part of your beauty journey.
</p>

<hr style="margin:30px 0;border:0;height:2px;background:linear-gradient(90deg,transparent,#667eea,transparent)"/>

<h2>Your Order Summary</h2>

<div>

<% products.forEach(function(product){ %>

<div style="display:flex;align-items:center;padding:20px;background:#f8f9fa;border-radius:12px;margin-bottom:15px;">

<img src="<%= product.img %>"
style="width:80px;height:80px;object-fit:cover;border-radius:8px;margin-right:20px;"/>

<div style="flex:1">

<p style="font-weight:bold"><%= product.title %></p>
<p>Quantity: <%= product.quantity %></p>
<p>Price: $<%= product.price %></p>

</div>

</div>

<% }) %>

</div>

<div style="text-align:center;margin-top:30px;">
<a href="https://kilifoniabeauty.co.ke/track-order" class="cta-button">
Track Your Order
</a>
</div>

</div>

<!-- FOOTER -->
<div class="email-footer">

<p style="color:#f5576c;font-weight:bold;font-size:18px;">
Kilifonia Beauty
</p>

<p>Elevating Beauty Through Science and Nature</p>

<p>
&copy; <%= new Date().getFullYear() %> Kilifonia Beauty. All rights reserved.
</p>

</div>

</div>

</body>
</html>